# Environment Configuration
FLASK_ENV=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://payment_user:payment_password@localhost:5432/payment_db

# Application Configuration
PROJECT_NAME=Payment Gateway Service
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# CORS Configuration
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
