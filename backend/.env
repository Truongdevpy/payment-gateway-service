# Environment Configuration
FLASK_ENV=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://payment_user:payment_password@localhost:5432/payment_db

# Application Configuration
PROJECT_NAME=Payment Gateway Service
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
ENCRYPTION_KEY=QZSIIjZG3HV_PPGXKIafD8t-dFIjXy61iBwtjGWYKN4=

# CORS Configuration
ALLOWED_HOSTS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Email Configuration (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@thueapi.com
SMTP_FROM_NAME=ThueAPI
SMTP_USE_TLS=True

# ── Payment Gateways ─────────────────────────────────────────────────
# Momo
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
MOMO_API_ENDPOINT=https://test-payment.momo.vn
MOMO_PARTNER_NAME=Payment Gateway Service
MOMO_STORE_ID=demo-store
MOMO_STORE_NAME=Payment Gateway Demo
MOMO_REDIRECT_URL=http://localhost:3000/payments/momo/return
MOMO_IPN_URL=http://localhost:8000/api/payments/momo/ipn
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANG=vi

# ZaloPay
ZALOPAY_APP_ID=your-app-id
ZALOPAY_KEY1=your-key1
ZALOPAY_KEY2=your-key2
ZALOPAY_API_ENDPOINT=https://sb-openapi.zalopay.vn

# VCB Transfer
VCB_API_URL=
VCB_RSA_PUBLIC_KEY=
VCB_MERCHANT_ID=

# ── Scheduler ─────────────────────────────────────────────────────────
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
